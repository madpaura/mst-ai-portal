# MST AI Portal — Environment Configuration
# Copy to .env and customize as needed

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=mst_portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal123
DB_PORT=5432

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=9800
JWT_SECRET=change-me-in-production
AUTH_MODE=open          # open | ldap | saml
CORS_ORIGINS=["*"]
CORS_ALLOW_ORIGIN_REGEX=http?://(localhost|127\.0\.0\.1|107\.99\.41\.85)(:\d+)?

# ── ADFS / SAML 2.0 (only needed when AUTH_MODE=saml) ─────
# Your app's public URL — must match ACS/SLS URLs registered in ADFS
SAML_SP_ENTITY_ID=https://mst-ai-portal.ai.x.net/saml/metadata
SAML_SP_ACS_URL=https://mst-ai-portal.ai.x.net/saml/acs
SAML_SP_SLS_URL=https://mst-ai-portal.ai.x.net/saml/sls

# ADFS endpoints — get exact values from FederationMetadata.xml
SAML_IDP_ENTITY_ID=https://adfs.x.net/adfs/services/trust
SAML_IDP_SSO_URL=https://adfs.x.net/adfs/ls/
SAML_IDP_SLO_URL=https://adfs.x.net/adfs/ls/?wa=wsignout1.0

# Certs — base64 only (no -----BEGIN/END----- headers)
# Run: api/saml/gen_sp_cert.sh  then copy the .b64 file contents here
SAML_SP_CERT=
SAML_SP_KEY=
# ADFS token-signing cert (from AD admin → ADFS Management → Service → Certificates → Export)
SAML_IDP_CERT=

# AD group → portal role mapping (comma-separated, GroupName=role pairs)
# Roles: admin | user
SAML_GROUP_ROLE_MAP=AI-Ignite-Team=admin,Samsung-Developers=user
SAML_DEFAULT_ROLE=user

# Alternatively, point to a settings.json file instead of using env vars above:
# SAML_SETTINGS_PATH=/app/saml/settings.json


# ── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=9810
VITE_API_URL=http://localhost:9800

# ── Portal URL (used in email/newsletter links) ──────────
PORTAL_URL=http://localhost:9810

# ── Ollama / LLM ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── GPU Transcoding ───────────────────────────────────────
# "auto" = detect NVIDIA GPU at startup, fallback to CPU if absent
# "none" = force CPU encoding (libx264) even if GPU is available
FFMPEG_HWACCEL=auto


# ── Volumes ──────────────────────────────────────────────
VIDEO_DATA_VOLUME="./volumes/storage/videos"
MEDIA_DATA_VOLUME="./volumes/storage/media"
PG_DATA_VOLUME="./volumes/pg-data"
