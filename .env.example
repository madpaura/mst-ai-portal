# MST AI Portal — Environment Configuration
# Copy to .env and customize as needed

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=mst_portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal123
DB_PORT=5432

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=9800
JWT_SECRET=change-me-in-production
AUTH_MODE=open          # open | ldap | saml
CORS_ORIGINS=["*"]
CORS_ALLOW_ORIGIN_REGEX=http?://(localhost|127\.0\.0\.1|107\.99\.41\.85)(:\d+)?

# ── ADFS / SAML 2.0 (only needed when AUTH_MODE=saml) ─────
# Your app's public URL — must match ACS/SLS URLs registered in ADFS
SAML_SP_ENTITY_ID=https://mst-ai-portal.ai.x.net/saml/metadata
SAML_SP_ACS_URL=https://mst-ai-portal.ai.x.net/saml/acs
SAML_SP_SLS_URL=https://mst-ai-portal.ai.x.net/saml/sls

# ADFS endpoints — get exact values from FederationMetadata.xml
SAML_IDP_ENTITY_ID=https://adfs.x.net/adfs/services/trust
SAML_IDP_SSO_URL=https://adfs.x.net/adfs/ls/
SAML_IDP_SLO_URL=https://adfs.x.net/adfs/ls/?wa=wsignout1.0

# Certs — base64 only (no -----BEGIN/END----- headers)
# Run: api/saml/gen_sp_cert.sh  then copy the .b64 file contents here
SAML_SP_CERT=
SAML_SP_KEY=
# ADFS token-signing cert (from AD admin → ADFS Management → Service → Certificates → Export)
SAML_IDP_CERT=

# AD group → portal role mapping (comma-separated, GroupName=role pairs)
# Roles: admin | user
SAML_GROUP_ROLE_MAP=AI-Ignite-Team=admin,Samsung-Developers=user
SAML_DEFAULT_ROLE=user

# Use settings.json instead of env vars above (recommended for complex SAML configs):
SAML_SETTINGS_PATH=/app/saml/settings.json


# ── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=9810
VITE_API_URL=http://localhost:9800
# Set to show a beta tag in the navbar and browser title (e.g. BETA). Leave empty for production.
# VITE_BETA_TAG=BETA

# ── Portal URL (used in email/newsletter links) ──────────
# Set both to your public portal origin (e.g. https://portal.example.com).
# PORTAL_BASE_URL is used for "View on Portal" / review links in publish emails;
# if unset, docker-compose falls it back to PORTAL_URL.
PORTAL_URL=http://localhost:9810
PORTAL_BASE_URL=http://localhost:9810

# Prefix prepended to every outgoing email subject. Used as the default; it can
# be overridden at runtime in Admin → Settings → SMTP (subject_prefix). Set blank
# to disable prefixing.
EMAIL_SUBJECT_PREFIX=MSTAI-TF

# ── Ollama / LLM ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── SkillSpector (artifact security scanner) ─────────────
# NVIDIA SkillSpector runs as a sidecar container and scans submitted skill/MCP
# artifacts before they can be published. The backend reaches it at this URL.
SKILLSPECTOR_SERVICE_URL=http://skillspector:9200
# Host port the scanner binds to when HOST_NETWORK=true (bridge mode keeps it
# internal on 9200). Change only if 9200 is already taken on the host.
SKILLSPECTOR_PORT=9200
# Use the portal's active LLM (in-house OpenAI-compatible endpoint or Ollama) for
# SkillSpector's semantic stage — best precision. Requires the LLM's *model name*
# to be set in Admin → Settings (a custom base URL has no usable default model).
# Set false to run static-only analysis (no LLM, no keys, faster).
SKILLSPECTOR_USE_LLM=true
# When the scanner is unreachable: false = allow submit with a warning
# (fail-open), true = block submit (fail-closed).
SKILLSPECTOR_FAIL_CLOSED=false
# Per-scan HTTP timeout (seconds). LLM scans of large skills can be slow.
SKILLSPECTOR_TIMEOUT=180
# SkillSpector's own log level inside the sidecar (DEBUG|INFO|WARNING|ERROR).
SKILLSPECTOR_LOG_LEVEL=WARNING

# ── Artifact Hub GitHub publishing ────────────────────────
# Overall wall-clock budget (seconds) for a GitHub publish / delete round-trip.
# A single publish pushes every file plus MANIFEST.json + README.md, so allow
# generous headroom; on timeout the API returns a retriable error.
ARTIFACT_PUBLISH_TIMEOUT=120
ARTIFACT_DELETE_TIMEOUT=90
# Max combined size (MB) of all files in one artifact submission. Skills can
# ship sizeable data files (shape indexes, datasets), so keep this generous.
ARTIFACT_MAX_FILES_MB=25

# ── GPU Transcoding ───────────────────────────────────────
# "auto" = detect NVIDIA GPU at startup, fallback to CPU if absent
# "none" = force CPU encoding (libx264) even if GPU is available
FFMPEG_HWACCEL=auto

# ── Transcript Service ────────────────────────────────────
TRANSCRIPT_PORT=9100
TRANSCRIPT_API_KEY=change-me
TRANSCRIPT_MODEL=large-v3
# Set TRANSCRIPT_MOCK=true to skip the real transcript service and use a
# synthetic 10-minute transcript instead (useful for testing without a GPU).
TRANSCRIPT_MOCK=false
# Concurrent pipeline workers (each claims jobs independently — higher = more videos in parallel)
AUTO_PROCESSOR_CONCURRENCY=4


# ── Resource Limits (workers) ────────────────────────────
# Caps the three background workers to ~70% of host resources so content
# serving (backend, frontend, db) always has headroom.
# Tune these to match your host — defaults assume 12 CPU cores / 14 GB RAM.
WORKER_CPU_LIMIT=4.0        # ffmpeg transcoder (CPU-bound)
WORKER_MEM_LIMIT=4g
AUTO_PROCESSOR_CPU_LIMIT=2.0  # async LLM pipeline (mostly I/O wait)
AUTO_PROCESSOR_MEM_LIMIT=2g
TRANSCRIPT_CPU_LIMIT=4.0    # Whisper CPU inference
TRANSCRIPT_MEM_LIMIT=6g     # large-v3 needs ~4 GB RAM on CPU
TRANSCRIPT_GPU_CPU_LIMIT=2.0  # GPU mode: inference on VRAM, less CPU/RAM needed
TRANSCRIPT_GPU_MEM_LIMIT=4g

# ── Redis Cache ──────────────────────────────────────────
# Disable by setting REDIS_ENABLED=false (e.g. for local dev without Redis)
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_DEFAULT_TTL=300   # seconds — how long to cache read results

# ── Logging ───────────────────────────────────────────────
# Controls log verbosity for backend, worker, and auto-processor.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default is INFO. Use DEBUG during local development for verbose output.
LOG_LEVEL=INFO

# ── Backend concurrency ───────────────────────────────────
# Number of uvicorn worker processes for the backend. More workers use more
# CPU cores and lower latency under load. The startup DB migration and the
# forge scheduler are guarded by Postgres advisory locks, so they run exactly
# once no matter how many workers you set. A good starting point is the number
# of CPU cores you want to dedicate to the API (e.g. 4).
UVICORN_WORKERS=4

# asyncpg connection pool size — PER uvicorn worker. Total backend connections
# is DB_POOL_MAX × UVICORN_WORKERS, plus the transcoder / auto-processor /
# scheduler containers. Keep the sum below Postgres max_connections (default
# 100), or raise max_connections on the db service.
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Networking ────────────────────────────────────────────
# Default is "false" — services run on an isolated Docker bridge network and
# talk to each other by service name (db, redis, backend, …).
# Set to "true" if you hit connectivity issues on the host (host.docker.internal
# unresolved, firewalls blocking docker0, on-host Ollama unreachable, etc.).
# In host mode every container shares the host's network namespace; the override
# in docker-compose.hostnet.yml rewrites internal URLs to 127.0.0.1.
# Linux only — on Docker Desktop (Mac/Windows) keep this false.
HOST_NETWORK=false

# ── Build proxy (optional) ───────────────────────────────
# Corporate proxy for docker image builds. When set (here or in the shell
# environment), ./setup.sh deploy forwards them to every image build as
# --build-arg, so apt/pip/npm inside the Dockerfiles go through the proxy.
# Lowercase variants (http_proxy, …) are also recognised.
#HTTP_PROXY=http://proxy.example.com:8080
#HTTPS_PROXY=http://proxy.example.com:8080
#NO_PROXY=localhost,127.0.0.1,.example.com

# ── Volumes ──────────────────────────────────────────────
# Host paths for video/media storage, mounted into the containers by
# docker-compose. scripts/backup.sh and scripts/restore.sh read these too,
# so backups follow wherever you point the storage (override per-script with
# BACKUP_VIDEOS_DIR / BACKUP_MEDIA_DIR in scripts/backup.conf if needed).
VIDEO_DATA_VOLUME="./volumes/storage/videos"
MEDIA_DATA_VOLUME="./volumes/storage/media"
PG_DATA_VOLUME="./volumes/pg-data"
