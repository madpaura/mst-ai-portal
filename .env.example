# MST AI Portal — Environment Configuration
# Copy to .env and customize as needed

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=mst_portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal123
DB_PORT=5432

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=9800
JWT_SECRET=change-me-in-production
AUTH_MODE=open          # open | ldap
CORS_ORIGINS=["*"]
CORS_ALLOW_ORIGIN_REGEX=http?://(localhost|127\.0\.0\.1|107\.99\.41\.85)(:\d+)?


# ── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=9810
VITE_API_URL=http://localhost:9800

# ── Portal URL (used in email/newsletter links) ──────────
PORTAL_URL=http://localhost:9810

# ── Ollama / LLM ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── GPU Transcoding ───────────────────────────────────────
# "auto" = detect NVIDIA GPU at startup, fallback to CPU if absent
# "none" = force CPU encoding (libx264) even if GPU is available
FFMPEG_HWACCEL=auto


# ── Volumes ──────────────────────────────────────────────
VIDEO_DATA_VOLUME="./volumes/storage/videos"
MEDIA_DATA_VOLUME="./volumes/storage/media"
PG_DATA_VOLUME="./volumes/pg-data"
